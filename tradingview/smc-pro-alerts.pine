//@version=5
strategy("SMC PRO - Webhook Ready v0.3", overlay=true, pyramiding=0,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=1,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     slippage=1)

// ===== Core settings =====
pivot_len = input.int(5, "Pivot Length", minval=1)
rr = input.float(2.0, "Final TP RR", minval=0.5, step=0.1)
tp1_rr = input.float(1.0, "Payload TP1 RR", minval=0.25, step=0.25)
ema_len = input.int(50, "Local EMA Length", minval=1)
max_wait = input.int(10, "Max Bars After Sweep", minval=1)
min_bars_after_sweep = input.int(1, "Min Bars After Sweep", minval=0)
body_ratio = input.float(0.55, "Strong Candle Body %", minval=0.1, maxval=1.0)
webhook_secret = input.string("change-me", "Webhook Secret")

// ===== Higher timeframe filter =====
use_htf_filter = input.bool(true, "Use HTF Trend Filter")
htf = input.timeframe("60", "HTF Trend Timeframe")
htf_ema_len = input.int(100, "HTF EMA Length", minval=1)

// ===== Session and volatility filters =====
use_session_filter = input.bool(false, "Use Trade Session Filter")
trade_session = input.session("0800-2300", "Trade Session")
atr_len = input.int(14, "ATR Length", minval=1)
atr_buffer = input.float(0.2, "ATR SL Buffer", minval=0.0, step=0.1)
sweep_atr_buffer = input.float(0.05, "Sweep ATR Buffer", minval=0.0, step=0.01)
min_atr_pct = input.float(0.05, "Min ATR %", minval=0.0, step=0.01)
max_atr_pct = input.float(2.0, "Max ATR %", minval=0.1, step=0.1)

// ===== Risk filters =====
min_stop_pct = input.float(0.05, "Min Stop %", minval=0.0, step=0.01)
max_stop_pct = input.float(1.2, "Max Stop %", minval=0.1, step=0.1)
cooldown_bars = input.int(20, "Cooldown Bars After Signal", minval=0)

// ===== Trend =====
ema = ta.ema(close, ema_len)
atr = ta.atr(atr_len)
atr_pct = close != 0 ? atr / close * 100 : na

htf_close = request.security(syminfo.tickerid, htf, close, barmerge.gaps_off, barmerge.lookahead_off)
htf_ema = request.security(syminfo.tickerid, htf, ta.ema(close, htf_ema_len), barmerge.gaps_off, barmerge.lookahead_off)
htf_bull = htf_close > htf_ema
htf_bear = htf_close < htf_ema
htf_trend = htf_bull ? "bull" : htf_bear ? "bear" : "neutral"

local_bull = close > ema
local_bear = close < ema
trend_long_ok = local_bull and (not use_htf_filter or htf_bull)
trend_short_ok = local_bear and (not use_htf_filter or htf_bear)

// ===== Market quality filters =====
in_session = not use_session_filter or not na(time(timeframe.period, trade_session))
vol_ok = not na(atr_pct) and atr_pct >= min_atr_pct and atr_pct <= max_atr_pct

// ===== Pivot structure =====
ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low, pivot_len, pivot_len)

var float swing_high = na
var float swing_low = na

if not na(ph)
    swing_high := ph

if not na(pl)
    swing_low := pl

// ===== Candle strength =====
range_size = math.max(high - low, syminfo.mintick)
body_size = math.abs(close - open)
body_strength = body_size / range_size
strong_bull = close > open and body_strength >= body_ratio
strong_bear = close < open and body_strength >= body_ratio

// ===== Sweep state machine =====
var bool swept_low = false
var bool swept_high = false
var int swept_low_bar = na
var int swept_high_bar = na
var float swept_low_price = na
var float swept_high_price = na

new_sweep_low = not na(swing_low) and low < swing_low - atr * sweep_atr_buffer and close > swing_low
new_sweep_high = not na(swing_high) and high > swing_high + atr * sweep_atr_buffer and close < swing_high

if new_sweep_low
    swept_low := true
    swept_low_bar := bar_index
    swept_low_price := low
    swept_high := false

if new_sweep_high
    swept_high := true
    swept_high_bar := bar_index
    swept_high_price := high
    swept_low := false

if swept_low and not na(swept_low_bar) and bar_index - swept_low_bar > max_wait
    swept_low := false

if swept_high and not na(swept_high_bar) and bar_index - swept_high_bar > max_wait
    swept_high := false

sweep_low_ready = swept_low and not na(swept_low_bar) and bar_index - swept_low_bar >= min_bars_after_sweep
sweep_high_ready = swept_high and not na(swept_high_bar) and bar_index - swept_high_bar >= min_bars_after_sweep

// ===== CHoCH =====
bull_choch = sweep_low_ready and not na(swing_high) and close > swing_high and close[1] <= swing_high
bear_choch = sweep_high_ready and not na(swing_low) and close < swing_low and close[1] >= swing_low

// ===== SL / TP / risk =====
long_sl = swept_low_price - atr * atr_buffer
short_sl = swept_high_price + atr * atr_buffer

long_risk = close - long_sl
short_risk = short_sl - close
long_stop_pct = close != 0 ? long_risk / close * 100 : na
short_stop_pct = close != 0 ? short_risk / close * 100 : na

risk_ok_long = not na(long_stop_pct) and long_risk > syminfo.mintick and long_stop_pct >= min_stop_pct and long_stop_pct <= max_stop_pct
risk_ok_short = not na(short_stop_pct) and short_risk > syminfo.mintick and short_stop_pct >= min_stop_pct and short_stop_pct <= max_stop_pct

long_tp1 = close + long_risk * tp1_rr
short_tp1 = close - short_risk * tp1_rr
long_tp = close + long_risk * rr
short_tp = close - short_risk * rr

// ===== Cooldown =====
var int last_signal_bar = na
cooldown_ok = na(last_signal_bar) or bar_index - last_signal_bar >= cooldown_bars

// ===== Conditions =====
long_condition = barstate.isconfirmed and cooldown_ok and in_session and vol_ok and trend_long_ok and bull_choch and strong_bull and risk_ok_long
short_condition = barstate.isconfirmed and cooldown_ok and in_session and vol_ok and trend_short_ok and bear_choch and strong_bear and risk_ok_short

long_confidence = math.min(95, 50 + (use_htf_filter and htf_bull ? 10 : 0) + (vol_ok ? 10 : 0) + (strong_bull ? 10 : 0) + (risk_ok_long ? 10 : 0) + (in_session ? 5 : 0))
short_confidence = math.min(95, 50 + (use_htf_filter and htf_bear ? 10 : 0) + (vol_ok ? 10 : 0) + (strong_bear ? 10 : 0) + (risk_ok_short ? 10 : 0) + (in_session ? 5 : 0))

build_payload(side, sl, tp1, tp, risk_pct, confidence, reasons) =>
    '{"secret":"' + webhook_secret +
     '","event":"signal_open"' +
     ',"signal_id":"SMC_PRO:' + syminfo.tickerid + ':' + timeframe.period + ':' + str.tostring(time) + ':' + side +
     '","strategy":"SMC_PRO","version":"0.3.0","symbol":"' + syminfo.tickerid +
     '","timeframe":"' + timeframe.period +
     '","side":"' + side +
     '","entry":' + str.tostring(close) +
     ',"sl":' + str.tostring(sl) +
     ',"tp":' + str.tostring(tp) +
     ',"tp1":' + str.tostring(tp1) +
     ',"tp2":' + str.tostring(tp) +
     ',"rr":' + str.tostring(rr) +
     ',"risk_pct":' + str.tostring(risk_pct) +
     ',"atr_pct":' + str.tostring(atr_pct) +
     ',"htf_trend":"' + htf_trend +
     '","session":"' + (use_session_filter ? trade_session : "all") +
     '","confidence":' + str.tostring(confidence) +
     ',"reason":' + reasons +
     ',"created_at":' + str.tostring(time) + '}'

if long_condition and strategy.position_size == 0
    payload = build_payload("long", long_sl, long_tp1, long_tp, long_stop_pct, long_confidence, '["Sweep Low","Bullish CHoCH","HTF/EMA Bull","Strong Bull Candle","Risk OK"]')
    strategy.entry("Long", strategy.long, alert_message=payload)
    strategy.exit("L Exit", "Long", stop=long_sl, limit=long_tp)
    alert(payload, alert.freq_once_per_bar_close)
    swept_low := false
    last_signal_bar := bar_index

if short_condition and strategy.position_size == 0
    payload = build_payload("short", short_sl, short_tp1, short_tp, short_stop_pct, short_confidence, '["Sweep High","Bearish CHoCH","HTF/EMA Bear","Strong Bear Candle","Risk OK"]')
    strategy.entry("Short", strategy.short, alert_message=payload)
    strategy.exit("S Exit", "Short", stop=short_sl, limit=short_tp)
    alert(payload, alert.freq_once_per_bar_close)
    swept_high := false
    last_signal_bar := bar_index

plot(ema, "Local EMA", color=color.orange)
plot(htf_ema, "HTF EMA", color=color.new(color.blue, 35))
plotshape(new_sweep_low, "Sweep Low", shape.triangleup, location.belowbar, color=color.green, size=size.tiny)
plotshape(new_sweep_high, "Sweep High", shape.triangledown, location.abovebar, color=color.red, size=size.tiny)
plotshape(bull_choch, "Bull CHoCH", shape.circle, location.belowbar, color=color.new(color.green, 0), size=size.tiny)
plotshape(bear_choch, "Bear CHoCH", shape.circle, location.abovebar, color=color.new(color.red, 0), size=size.tiny)
plotshape(long_condition, "Long Signal", shape.labelup, location.belowbar, color=color.green, text="LONG", textcolor=color.white)
plotshape(short_condition, "Short Signal", shape.labeldown, location.abovebar, color=color.red, text="SHORT", textcolor=color.white)
