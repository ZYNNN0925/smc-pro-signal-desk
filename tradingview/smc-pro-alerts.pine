//@version=5
strategy("SMC PRO - ICT Model v0.5", overlay=true, pyramiding=0,
     process_orders_on_close=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=1,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     slippage=1)

// ===== Core settings =====
pivot_len = input.int(5, "Swing Pivot Length", minval=1)
rr = input.float(2.0, "Final TP RR", minval=0.5, step=0.1)
tp1_rr = input.float(1.0, "TP1 RR", minval=0.25, step=0.25)
use_partial_tp = input.bool(true, "Use TP1 Partial Exit")
tp1_qty_pct = input.float(50, "TP1 Exit Qty %", minval=1, maxval=99)
max_wait_after_sweep = input.int(10, "Max Bars Sweep -> MSS", minval=1)
min_bars_after_sweep = input.int(1, "Min Bars Sweep -> MSS", minval=0)
max_wait_after_mss = input.int(12, "Max Bars MSS -> Entry", minval=1)
body_ratio = input.float(0.55, "Min Displacement Body %", minval=0.1, maxval=1.0)
webhook_secret = input.string("change-me", "Webhook Secret")
send_alert_function = input.bool(true, "Send alert() Webhook")

// ===== ICT / SMC model =====
entry_model = input.string("FVG Retest", "ICT Entry Model", options=["FVG Retest", "MSS Close"])
use_fvg_filter = input.bool(true, "Require FVG On MSS Candle")
use_fvg_ce = input.bool(true, "Enter At FVG Consequent Encroachment")
min_fvg_atr = input.float(0.05, "Min FVG Size ATR", minval=0.0, step=0.01)
use_pd_filter = input.bool(true, "Use Premium / Discount Filter")
long_max_pd_position = input.float(0.62, "Long Max Dealing Range Position", minval=0.1, maxval=1.0, step=0.01)
short_min_pd_position = input.float(0.38, "Short Min Dealing Range Position", minval=0.0, maxval=0.9, step=0.01)
order_block_lookback = input.int(10, "Order Block Lookback", minval=1, maxval=50)

// ===== Trend filters =====
ema_len = input.int(50, "Local EMA Length", minval=1)
use_ema_filter = input.bool(true, "Use Local EMA Filter")
use_ema_slope_filter = input.bool(true, "Use EMA Slope Filter")
ema_slope_len = input.int(3, "EMA Slope Lookback", minval=1)
use_htf_filter = input.bool(true, "Use Confirmed HTF Bias")
htf = input.timeframe("60", "HTF Bias Timeframe")
htf_ema_len = input.int(100, "HTF EMA Length", minval=1)

// ===== Session and market quality filters =====
use_session_filter = input.bool(false, "Use Trade Session Filter")
trade_session = input.session("0800-2300", "Trade Session")
use_killzone_filter = input.bool(false, "Use ICT Killzones")
london_killzone = input.session("0700-1000", "London Killzone")
ny_killzone = input.session("1230-1600", "New York Killzone")
atr_len = input.int(14, "ATR Length", minval=1)
atr_buffer = input.float(0.2, "ATR SL Buffer", minval=0.0, step=0.1)
sweep_atr_buffer = input.float(0.05, "Sweep ATR Buffer", minval=0.0, step=0.01)
mss_atr_buffer = input.float(0.02, "MSS Break ATR Buffer", minval=0.0, step=0.01)
min_atr_pct = input.float(0.05, "Min ATR %", minval=0.0, step=0.01)
max_atr_pct = input.float(2.0, "Max ATR %", minval=0.1, step=0.1)
use_displacement_filter = input.bool(true, "Use Displacement Filter")
displacement_atr_mult = input.float(0.35, "Min Displacement Range ATR", minval=0.0, step=0.05)
use_volume_filter = input.bool(false, "Use Volume Filter")
volume_len = input.int(20, "Volume MA Length", minval=1)
min_volume_mult = input.float(0.8, "Min Volume x MA", minval=0.0, step=0.1)

// ===== Risk filters =====
min_stop_pct = input.float(0.05, "Min Stop %", minval=0.0, step=0.01)
max_stop_pct = input.float(1.2, "Max Stop %", minval=0.1, step=0.1)
cooldown_bars = input.int(20, "Cooldown Bars After Signal", minval=0)

// ===== Trend and quality =====
ema = ta.ema(close, ema_len)
atr = ta.atr(atr_len)
atr_pct = close != 0 ? atr / close * 100 : na

// Uses the previous confirmed HTF candle so realtime HTF bias does not repaint.
htf_close = request.security(syminfo.tickerid, htf, close[1], barmerge.gaps_off, barmerge.lookahead_on)
htf_ema = request.security(syminfo.tickerid, htf, ta.ema(close, htf_ema_len)[1], barmerge.gaps_off, barmerge.lookahead_on)
htf_bull = htf_close > htf_ema
htf_bear = htf_close < htf_ema
htf_trend = not use_htf_filter ? "disabled" : htf_bull ? "bull" : htf_bear ? "bear" : "neutral"

local_bull = (not use_ema_filter or close > ema) and (not use_ema_slope_filter or ema > ema[ema_slope_len])
local_bear = (not use_ema_filter or close < ema) and (not use_ema_slope_filter or ema < ema[ema_slope_len])
trend_long_ok = local_bull and (not use_htf_filter or htf_bull)
trend_short_ok = local_bear and (not use_htf_filter or htf_bear)

in_session = not use_session_filter or not na(time(timeframe.period, trade_session))
in_london_kz = not na(time(timeframe.period, london_killzone))
in_ny_kz = not na(time(timeframe.period, ny_killzone))
in_killzone = not use_killzone_filter or in_london_kz or in_ny_kz
vol_ok = not na(atr_pct) and atr_pct >= min_atr_pct and atr_pct <= max_atr_pct
volume_ma = ta.sma(volume, volume_len)
volume_ok = not use_volume_filter or (not na(volume_ma) and volume >= volume_ma * min_volume_mult)

// ===== Market structure =====
ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low, pivot_len, pivot_len)

var float swing_high = na
var float swing_low = na

if not na(ph)
    swing_high := ph

if not na(pl)
    swing_low := pl

range_size = math.max(high - low, syminfo.mintick)
body_size = math.abs(close - open)
body_strength = body_size / range_size
displacement_ok = not use_displacement_filter or (not na(atr) and range_size >= atr * displacement_atr_mult)
strong_bull = close > open and body_strength >= body_ratio and displacement_ok
strong_bear = close < open and body_strength >= body_ratio and displacement_ok

// ===== ICT fair value gaps and order blocks =====
bullish_fvg = not na(high[2]) and low > high[2]
bearish_fvg = not na(low[2]) and high < low[2]
bullish_fvg_size = bullish_fvg ? low - high[2] : 0.0
bearish_fvg_size = bearish_fvg ? low[2] - high : 0.0
bullish_fvg_ok = not use_fvg_filter or (bullish_fvg and bullish_fvg_size >= atr * min_fvg_atr)
bearish_fvg_ok = not use_fvg_filter or (bearish_fvg and bearish_fvg_size >= atr * min_fvg_atr)

find_bullish_ob_low(max_bars) =>
    float level = na
    for i = 1 to max_bars
        if na(level) and close[i] < open[i]
            level := low[i]
    level

find_bullish_ob_high(max_bars) =>
    float level = na
    for i = 1 to max_bars
        if na(level) and close[i] < open[i]
            level := high[i]
    level

find_bearish_ob_low(max_bars) =>
    float level = na
    for i = 1 to max_bars
        if na(level) and close[i] > open[i]
            level := low[i]
    level

find_bearish_ob_high(max_bars) =>
    float level = na
    for i = 1 to max_bars
        if na(level) and close[i] > open[i]
            level := high[i]
    level

// ===== Liquidity sweep state =====
var bool swept_low = false
var bool swept_high = false
var int swept_low_bar = na
var int swept_high_bar = na
var float swept_low_price = na
var float swept_high_price = na
var float swept_low_atr = na
var float swept_high_atr = na
var float long_mss_level = na
var float short_mss_level = na

new_sweep_low = not na(swing_low) and not na(swing_high) and low < swing_low - atr * sweep_atr_buffer and close > swing_low
new_sweep_high = not na(swing_high) and not na(swing_low) and high > swing_high + atr * sweep_atr_buffer and close < swing_high

if new_sweep_low
    swept_low := true
    swept_low_bar := bar_index
    swept_low_price := low
    swept_low_atr := atr
    long_mss_level := swing_high
    swept_high := false
    swept_high_bar := na
    swept_high_price := na
    swept_high_atr := na
    short_mss_level := na

if new_sweep_high
    swept_high := true
    swept_high_bar := bar_index
    swept_high_price := high
    swept_high_atr := atr
    short_mss_level := swing_low
    swept_low := false
    swept_low_bar := na
    swept_low_price := na
    swept_low_atr := na
    long_mss_level := na

if swept_low and not na(swept_low_bar) and bar_index - swept_low_bar > max_wait_after_sweep
    swept_low := false
    swept_low_bar := na
    swept_low_price := na
    swept_low_atr := na
    long_mss_level := na

if swept_high and not na(swept_high_bar) and bar_index - swept_high_bar > max_wait_after_sweep
    swept_high := false
    swept_high_bar := na
    swept_high_price := na
    swept_high_atr := na
    short_mss_level := na

sweep_low_ready = swept_low and not na(swept_low_bar) and bar_index - swept_low_bar >= min_bars_after_sweep
sweep_high_ready = swept_high and not na(swept_high_bar) and bar_index - swept_high_bar >= min_bars_after_sweep

// MSS = market structure shift after liquidity has been taken.
bull_break_level = not na(long_mss_level) ? long_mss_level + atr * mss_atr_buffer : na
bear_break_level = not na(short_mss_level) ? short_mss_level - atr * mss_atr_buffer : na
bull_mss = sweep_low_ready and not na(bull_break_level) and close > bull_break_level and close[1] <= nz(bull_break_level[1], bull_break_level)
bear_mss = sweep_high_ready and not na(bear_break_level) and close < bear_break_level and close[1] >= nz(bear_break_level[1], bear_break_level)

// ===== Pending ICT setups =====
var bool long_setup = false
var bool short_setup = false
var int long_setup_bar = na
var int short_setup_bar = na
var float long_setup_sl = na
var float short_setup_sl = na
var float long_dealing_low = na
var float long_dealing_high = na
var float short_dealing_low = na
var float short_dealing_high = na
var float long_fvg_bottom = na
var float long_fvg_top = na
var float long_fvg_mid = na
var float short_fvg_bottom = na
var float short_fvg_top = na
var float short_fvg_mid = na
var float long_ob_low = na
var float long_ob_high = na
var float short_ob_low = na
var float short_ob_high = na
var bool long_setup_has_fvg = false
var bool short_setup_has_fvg = false
var int last_signal_bar = na

cooldown_ok = na(last_signal_bar) or bar_index - last_signal_bar >= cooldown_bars

base_quality_long = barstate.isconfirmed and cooldown_ok and strategy.position_size == 0 and in_session and in_killzone and vol_ok and volume_ok and trend_long_ok
base_quality_short = barstate.isconfirmed and cooldown_ok and strategy.position_size == 0 and in_session and in_killzone and vol_ok and volume_ok and trend_short_ok
long_setup_trigger = base_quality_long and bull_mss and strong_bull and bullish_fvg_ok
short_setup_trigger = base_quality_short and bear_mss and strong_bear and bearish_fvg_ok

if long_setup_trigger
    long_setup := true
    short_setup := false
    long_setup_bar := bar_index
    long_setup_sl := swept_low_price - nz(swept_low_atr, atr) * atr_buffer
    long_dealing_low := swept_low_price
    long_dealing_high := high
    long_fvg_bottom := bullish_fvg ? high[2] : low
    long_fvg_top := bullish_fvg ? low : high
    long_fvg_mid := (long_fvg_bottom + long_fvg_top) / 2.0
    long_ob_low := find_bullish_ob_low(order_block_lookback)
    long_ob_high := find_bullish_ob_high(order_block_lookback)
    long_setup_has_fvg := bullish_fvg_ok
    short_setup_has_fvg := false
    swept_low := false
    swept_low_bar := na
    swept_low_price := na
    swept_low_atr := na
    long_mss_level := na

if short_setup_trigger
    short_setup := true
    long_setup := false
    short_setup_bar := bar_index
    short_setup_sl := swept_high_price + nz(swept_high_atr, atr) * atr_buffer
    short_dealing_high := swept_high_price
    short_dealing_low := low
    short_fvg_top := bearish_fvg ? low[2] : low
    short_fvg_bottom := bearish_fvg ? high : low
    short_fvg_mid := (short_fvg_bottom + short_fvg_top) / 2.0
    short_ob_low := find_bearish_ob_low(order_block_lookback)
    short_ob_high := find_bearish_ob_high(order_block_lookback)
    short_setup_has_fvg := bearish_fvg_ok
    long_setup_has_fvg := false
    swept_high := false
    swept_high_bar := na
    swept_high_price := na
    swept_high_atr := na
    short_mss_level := na

if long_setup and (bar_index - long_setup_bar > max_wait_after_mss or low <= long_setup_sl)
    long_setup := false
    long_setup_has_fvg := false

if short_setup and (bar_index - short_setup_bar > max_wait_after_mss or high >= short_setup_sl)
    short_setup := false
    short_setup_has_fvg := false

// ===== Entry and risk =====
safe_tp1_rr = math.min(tp1_rr, rr)
long_entry = close
short_entry = close
long_sl = long_setup ? long_setup_sl : na
short_sl = short_setup ? short_setup_sl : na

long_risk = not na(long_sl) ? long_entry - long_sl : na
short_risk = not na(short_sl) ? short_sl - short_entry : na
long_stop_pct = not na(long_risk) and long_entry != 0 ? long_risk / long_entry * 100 : na
short_stop_pct = not na(short_risk) and short_entry != 0 ? short_risk / short_entry * 100 : na
risk_ok_long = not na(long_stop_pct) and long_risk > syminfo.mintick and long_stop_pct >= min_stop_pct and long_stop_pct <= max_stop_pct
risk_ok_short = not na(short_stop_pct) and short_risk > syminfo.mintick and short_stop_pct >= min_stop_pct and short_stop_pct <= max_stop_pct

long_dealing_range = long_dealing_high - long_dealing_low
short_dealing_range = short_dealing_high - short_dealing_low
long_pd_position = long_dealing_range > syminfo.mintick ? (close - long_dealing_low) / long_dealing_range : na
short_pd_position = short_dealing_range > syminfo.mintick ? (close - short_dealing_low) / short_dealing_range : na
pd_ok_long = not use_pd_filter or (not na(long_pd_position) and long_pd_position <= long_max_pd_position)
pd_ok_short = not use_pd_filter or (not na(short_pd_position) and short_pd_position >= short_min_pd_position)

long_fvg_target = use_fvg_ce ? long_fvg_mid : long_fvg_top
short_fvg_target = use_fvg_ce ? short_fvg_mid : short_fvg_bottom
long_fvg_retest = long_setup and entry_model == "FVG Retest" and bar_index > long_setup_bar and low <= long_fvg_target and close > long_fvg_bottom and close > open
short_fvg_retest = short_setup and entry_model == "FVG Retest" and bar_index > short_setup_bar and high >= short_fvg_target and close < short_fvg_top and close < open
long_mss_close_entry = long_setup_trigger and entry_model == "MSS Close"
short_mss_close_entry = short_setup_trigger and entry_model == "MSS Close"
pd_entry_ok_long = entry_model == "MSS Close" ? true : pd_ok_long
pd_entry_ok_short = entry_model == "MSS Close" ? true : pd_ok_short

long_condition = barstate.isconfirmed and strategy.position_size == 0 and risk_ok_long and pd_entry_ok_long and (long_mss_close_entry or long_fvg_retest)
short_condition = barstate.isconfirmed and strategy.position_size == 0 and risk_ok_short and pd_entry_ok_short and (short_mss_close_entry or short_fvg_retest)

long_tp1 = not na(long_risk) ? long_entry + long_risk * safe_tp1_rr : na
short_tp1 = not na(short_risk) ? short_entry - short_risk * safe_tp1_rr : na
long_tp = not na(long_risk) ? long_entry + long_risk * rr : na
short_tp = not na(short_risk) ? short_entry - short_risk * rr : na

long_confidence = math.min(95, 35 + (trend_long_ok ? 10 : 0) + (bull_mss or long_setup ? 15 : 0) + (long_setup_has_fvg or bullish_fvg_ok ? 15 : 0) + (pd_entry_ok_long ? 10 : 0) + (in_killzone ? 5 : 0) + (risk_ok_long ? 10 : 0))
short_confidence = math.min(95, 35 + (trend_short_ok ? 10 : 0) + (bear_mss or short_setup ? 15 : 0) + (short_setup_has_fvg or bearish_fvg_ok ? 15 : 0) + (pd_entry_ok_short ? 10 : 0) + (in_killzone ? 5 : 0) + (risk_ok_short ? 10 : 0))

json_escape(value) =>
    str.replace_all(str.replace_all(value, "\\", "\\\\"), "\"", "\\\"")

json_text(value) =>
    "\"" + json_escape(value) + "\""

json_num(value) =>
    str.tostring(value, "#.########")

build_payload(side, entry, sl, tp1, tp, risk_pct, confidence, reasons) =>
    signal_id = "SMC_PRO:" + syminfo.tickerid + ":" + timeframe.period + ":" + str.tostring(time_close) + ":" + side
    "{" +
     "\"secret\":" + json_text(webhook_secret) +
     ",\"event\":\"signal_open\"" +
     ",\"signal_id\":" + json_text(signal_id) +
     ",\"strategy\":\"SMC_PRO\"" +
     ",\"version\":\"0.5.0\"" +
     ",\"symbol\":" + json_text(syminfo.tickerid) +
     ",\"timeframe\":" + json_text(timeframe.period) +
     ",\"side\":" + json_text(side) +
     ",\"entry\":" + json_num(entry) +
     ",\"sl\":" + json_num(sl) +
     ",\"tp\":" + json_num(tp) +
     ",\"tp1\":" + json_num(tp1) +
     ",\"tp2\":" + json_num(tp) +
     ",\"rr\":" + json_num(rr) +
     ",\"risk_pct\":" + json_num(risk_pct) +
     ",\"atr_pct\":" + json_num(atr_pct) +
     ",\"htf_trend\":" + json_text(htf_trend) +
     ",\"entry_model\":" + json_text(entry_model) +
     ",\"session\":" + json_text(use_session_filter ? trade_session : "all") +
     ",\"killzone\":" + json_text(in_london_kz ? "london" : in_ny_kz ? "new_york" : "none") +
     ",\"confidence\":" + str.tostring(confidence) +
     ",\"reason\":" + reasons +
     ",\"created_at\":" + str.tostring(time_close) +
     "}"

long_reasons = entry_model == "FVG Retest" ? "[\"Sell-side Liquidity Sweep\",\"Bullish MSS\",\"Bullish FVG Retest\",\"Discount/OTE OK\",\"Risk OK\"]" : "[\"Sell-side Liquidity Sweep\",\"Bullish MSS\",\"Displacement FVG\",\"Risk OK\"]"
short_reasons = entry_model == "FVG Retest" ? "[\"Buy-side Liquidity Sweep\",\"Bearish MSS\",\"Bearish FVG Retest\",\"Premium/OTE OK\",\"Risk OK\"]" : "[\"Buy-side Liquidity Sweep\",\"Bearish MSS\",\"Displacement FVG\",\"Risk OK\"]"

if long_condition
    payload = build_payload("long", long_entry, long_sl, long_tp1, long_tp, long_stop_pct, long_confidence, long_reasons)
    strategy.entry("Long", strategy.long, alert_message=payload)
    if use_partial_tp and safe_tp1_rr < rr
        strategy.exit("L TP1", "Long", stop=long_sl, limit=long_tp1, qty_percent=tp1_qty_pct)
        strategy.exit("L TP2", "Long", stop=long_sl, limit=long_tp, qty_percent=100 - tp1_qty_pct)
    else
        strategy.exit("L Exit", "Long", stop=long_sl, limit=long_tp)
    if send_alert_function
        alert(payload, alert.freq_once_per_bar_close)
    long_setup := false
    long_setup_has_fvg := false
    last_signal_bar := bar_index

if short_condition
    payload = build_payload("short", short_entry, short_sl, short_tp1, short_tp, short_stop_pct, short_confidence, short_reasons)
    strategy.entry("Short", strategy.short, alert_message=payload)
    if use_partial_tp and safe_tp1_rr < rr
        strategy.exit("S TP1", "Short", stop=short_sl, limit=short_tp1, qty_percent=tp1_qty_pct)
        strategy.exit("S TP2", "Short", stop=short_sl, limit=short_tp, qty_percent=100 - tp1_qty_pct)
    else
        strategy.exit("S Exit", "Short", stop=short_sl, limit=short_tp)
    if send_alert_function
        alert(payload, alert.freq_once_per_bar_close)
    short_setup := false
    short_setup_has_fvg := false
    last_signal_bar := bar_index

plot(ema, "Local EMA", color=color.orange)
plot(htf_ema, "Confirmed HTF EMA", color=color.new(color.blue, 35))
plot(bull_break_level, "Bullish MSS Level", color=color.new(color.green, 75), style=plot.style_linebr)
plot(bear_break_level, "Bearish MSS Level", color=color.new(color.red, 75), style=plot.style_linebr)
plot(long_setup ? long_fvg_top : na, "Bullish FVG Top", color=color.new(color.green, 65), style=plot.style_linebr)
plot(long_setup ? long_fvg_bottom : na, "Bullish FVG Bottom", color=color.new(color.green, 65), style=plot.style_linebr)
plot(short_setup ? short_fvg_top : na, "Bearish FVG Top", color=color.new(color.red, 65), style=plot.style_linebr)
plot(short_setup ? short_fvg_bottom : na, "Bearish FVG Bottom", color=color.new(color.red, 65), style=plot.style_linebr)
plot(long_setup ? long_ob_high : na, "Bullish OB High", color=color.new(color.teal, 80), style=plot.style_linebr)
plot(long_setup ? long_ob_low : na, "Bullish OB Low", color=color.new(color.teal, 80), style=plot.style_linebr)
plot(short_setup ? short_ob_high : na, "Bearish OB High", color=color.new(color.purple, 80), style=plot.style_linebr)
plot(short_setup ? short_ob_low : na, "Bearish OB Low", color=color.new(color.purple, 80), style=plot.style_linebr)
plotshape(new_sweep_low, "Sell-side Sweep", shape.triangleup, location.belowbar, color=color.green, size=size.tiny)
plotshape(new_sweep_high, "Buy-side Sweep", shape.triangledown, location.abovebar, color=color.red, size=size.tiny)
plotshape(bull_mss, "Bullish MSS", shape.circle, location.belowbar, color=color.new(color.green, 0), size=size.tiny)
plotshape(bear_mss, "Bearish MSS", shape.circle, location.abovebar, color=color.new(color.red, 0), size=size.tiny)
plotshape(long_condition, "Long Entry", shape.labelup, location.belowbar, color=color.green, text="ICT LONG", textcolor=color.white)
plotshape(short_condition, "Short Entry", shape.labeldown, location.abovebar, color=color.red, text="ICT SHORT", textcolor=color.white)
